# Environment variables for docker-compose
# Copy this file to .env and customize values as needed
# For development, docker-compose.yml already has defaults, so .env is optional

# Database Configuration
DATABASE_USERNAME=musicboxd
DATABASE_PASSWORD=your-secure-password-here

# JWT Configuration
JWT_SECRET=your-256-bit-secret-here
JWT_ACCESS_EXPIRATION=480000
JWT_REFRESH_EXPIRATION=86400000

# Email Configuration (Gmail App Password required)
MAILER_HOST=smtp.gmail.com
MAILER_PORT=587
MAILER_EMAIL=your-email@gmail.com
MAILER_PASSWORD=your-gmail-app-password

# Application URLs (for production deployment)
APP_URL_BASE=http://pawserver.it.itba.edu.ar/paw-2024b-02
APP_FRONTEND=http://pawserver.it.itba.edu.ar/paw-2024b-02
APP_BACKEND=http://pawserver.it.itba.edu.ar/paw-2024b-02/api
NEXT_PUBLIC_API_BASE_URL=http://pawserver.it.itba.edu.ar/paw-2024b-02/api
